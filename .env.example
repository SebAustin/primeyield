# ---------------------------------------------------------------------------
# PrimeYield environment configuration
# Copy to `.env` and fill in real values. NEVER commit the populated .env.
# ---------------------------------------------------------------------------

# --- Mantle RPC endpoints ---
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
# The active network the agent runs against (defaults to Sepolia for dev).
MANTLE_ACTIVE_RPC=https://rpc.sepolia.mantle.xyz

# --- Signing keys ---
# EOA used by the agent to register, record decisions, and submit swaps.
PRIVATE_KEY=0xYOUR_AGENT_EOA_PRIVATE_KEY
# Second signer for the 2-of-2 emergencyExit on the vault.
GUARDIAN_ADDRESS=0xYOUR_GUARDIAN_ADDRESS

# --- IPFS / Pinata (agent-card pinning) ---
PINATA_JWT=YOUR_PINATA_JWT

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LLM provider selection ---
# openai | anthropic. Blank = auto (OpenAI if OPENAI_API_KEY set, else Anthropic).
LLM_PROVIDER=
OPENAI_API_KEY=sk-proj-...
# Optional overrides: OPENAI_MODEL (default gpt-4o), ANTHROPIC_MODEL (default claude-sonnet-4-5).

# --- LangSmith tracing ---
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=primeyield

# --- Telegram approval bot ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# --- Persistence ---
# Postgres (with pgvector) connection string for the decision log + embeddings.
DATABASE_URL=postgresql://user:pass@localhost:5432/primeyield

# --- Optional: block explorer verification ---
MANTLESCAN_API_KEY=
